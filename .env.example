# ---- AI engine (optional) ----
# OpenRouter API key. Leave empty to use the built-in heuristic engine.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model slug (optional). Defaults to anthropic/claude-haiku-4.5
OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# Live web research via OpenRouter's web plugin. "true" (default) or "false".
# Note: web search adds per-request cost on OpenRouter.
OPENROUTER_WEB_SEARCH=true

# ---- Admin dashboard (optional) ----
# Password for the /admin dashboard. If empty, /admin shows "not configured".
ADMIN_PASSWORD=

# Supabase project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=

# Supabase SERVICE ROLE key (Project Settings > API). Server-side only — keep secret.
# Do NOT prefix with NEXT_PUBLIC. Never commit this value.
SUPABASE_SERVICE_ROLE_KEY=
